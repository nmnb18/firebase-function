rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSeller() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/seller_profiles/$(request.auth.uid));
    }
    
    function isSellerOwner(sellerId) {
      return isAuthenticated() && request.auth.uid == sellerId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ════════════════════════════════════════════════════════════════
    // USER AUTHENTICATION & PROFILES
    // ════════════════════════════════════════════════════════════════
    
    // Core user records — read own only, writes via Cloud Functions only
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin();
      allow create, delete: if false; // Only Cloud Functions
    }
    
    // Customer profiles — read own data, sellers can read for transactions
    match /customer_profiles/{userId} {
      allow read: if isOwner(userId) || isSeller() || isAdmin();
      allow write: if false; // Only Cloud Functions
    }
    
    // Seller profiles — public read for discovery, admin write only
    match /seller_profiles/{sellerId} {
      allow read: if true; // Public store listing/discovery
      allow update: if isAdmin();
      allow create, delete: if false; // Only Cloud Functions
    }
    
    // Seller subscriptions — seller can read own
    match /seller_subscriptions/{sellerId} {
      allow read: if isSellerOwner(sellerId) || isAdmin();
      allow update: if isAdmin();
      allow create, delete: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // POINTS & TRANSACTIONS
    // ════════════════════════════════════════════════════════════════
    
    // Points collection — read own points only
    match /points/{docId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false; // Only Cloud Functions
    }
    
    // Points hold — read own only (used during redemption)
    match /point_holds/{docId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false;
    }
    
    // Transaction history — read own transactions
    match /transactions/{txId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false; // Only Cloud Functions
    }
    
    // Daily scans audit log — read own only
    match /daily_scans/{scanId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // PAYMENTS & ORDERS
    // ════════════════════════════════════════════════════════════════
    
    // Subscription payments — read own only
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.seller_id == request.auth.uid);
      allow update: if isAdmin();
      allow create, delete: if false;
    }
    
    // UPI payment orders — read own only
    match /upi_payment_orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow write: if false; // Only Cloud Functions
    }

    // User payments (QR/UPI scan payments) — admin read all, user read own
    match /user_payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow write: if false; // Only Cloud Functions
    }
    
    // Coupons — read active coupons only
    match /coupons/{couponId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.status == 'active');
      allow write: if false;
    }
    
    // Coupon usage — read own usage
    match /coupon_usage/{usageId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // REDEMPTIONS
    // ════════════════════════════════════════════════════════════════
    
    // Redemption requests — read own redemptions
    match /redemptions/{redemptionId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false; // Only Cloud Functions
    }
    
    // Today's offer claims — read own claims
    match /today_offer_claims/{claimId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow write: if false;
    }
    
    // Offer redemptions — read own
    match /offer_redemptions/{redemptionId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() &&
                      (resource.data.user_id == request.auth.uid ||
                       resource.data.seller_id == request.auth.uid));
      allow write: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // QR CODES & TOKENS
    // ════════════════════════════════════════════════════════════════
    
    // QR tokens — no client access (security-critical)
    match /qr_tokens/{tokenId} {
      allow read, write: if false; // Only Cloud Functions
    }
    
    // User QR data — read own only
    match /user_qr/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }
    
    // QR codes (seller-generated) — read own only
    match /qr_codes/{qrId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.seller_id == request.auth.uid);
      allow update, delete: if isAdmin();
      allow create: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // NOTIFICATIONS & PUSH TOKENS
    // ════════════════════════════════════════════════════════════════
    
    // User notifications subcollection — read own notifications
    match /user_notifications/{userId}/notifications/{notifId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions
    }
    
    // Push tokens — users can register/update their own tokens
    match /push_tokens/{tokenId} {
      allow read: if false; // No client reads (privacy)
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
    
    // Scans audit log — admin read only
    match /scans/{scanId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════
    // SELLER-SPECIFIC COLLECTIONS
    // ════════════════════════════════════════════════════════════════
    
    // Seller daily offers — public read for discovery
    match /seller_daily_offers/{offerId} {
      allow read: if true; // Public (for "Today's Offers" feature)
      allow write: if isAdmin(); // Admin can create/update/delete offers
    }
    
    // Subscription history subcollection — seller reads own
    match /subscription_history/{sellerId}/records/{recordId} {
      allow read: if isSellerOwner(sellerId);
      allow write: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // APP CONFIGURATION
    // ════════════════════════════════════════════════════════════════
    
    // App settings — public read (e.g., city_config for registration validation)
    match /app_settings/{docId} {
      allow read: if true; // Public config
      allow write: if false; // Only admin/Cloud Functions
    }
    
    // Error logs — admin read; no client writes
    match /error_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    // City enquiries — aggregate counter per city (admin reads via Cloud Functions)
    match /city_enquiries/{cityKey} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Only admin

      // Per-user enquiry sub-docs — security data, admin SDK only
      match /enquiries/{docId} {
        allow read, write: if false;
      }
    }

    // City access log — IP + user-agent telemetry for security monitoring
    // Written only by Cloud Functions (Admin SDK). No client access.
    match /city_access_log/{docId} {
      allow read, write: if false;
    }
    
    // ════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ════════════════════════════════════════════════════════════════
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
