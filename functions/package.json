{
  "name": "grabbitt-functions",
  "description": "Firebase Cloud Functions for Grabbitt Seller App",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint --ext .ts src",
    "build": "tsc",
    "dev": "npm run build && node lib/server.js",
    "serve": "npm run build && firebase emulators:start --only functions,auth,firestore,ui,storage",
    "shell": "firebase functions:shell",
    "start": "npm run serve",
    "deploy": "npm run build && firebase deploy --only functions",
    "test": "jest --forceExit",
    "test:smoke": "jest --testPathPattern=tests/smoke --forceExit",
    "test:sanity": "jest --testPathPattern=tests/sanity --forceExit",
    "test:regression": "jest --testPathPattern=tests/regression --forceExit --runInBand",
    "test:unit": "jest --testPathPattern=calculate-reward-points.unit --forceExit",
    "test:all": "jest --forceExit",
    "test:coverage": "jest --coverage",
    "test:report": "allure generate allure-results -o allure-report --clean",
    "test:report:open": "allure open allure-report"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "base64-img": "^1.0.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "expo-server-sdk": "^4.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "allure-commandline": "^2.30.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "jest-allure2-reporter": "^2.3.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "private": true
}
